# --- AI captions (provider auto-detected from whichever key is set) ---
# FREE option (recommended): Groq — get a key at console.groq.com, no credit card.
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# Alternatives (set CAPTION_PROVIDER or just provide the key):
# XAI_API_KEY=xai-...            # Grok (needs xAI credits)
# GROK_MODEL=grok-3
# GEMINI_API_KEY=...             # Google Gemini (free: aistudio.google.com)

# --- AI image generation (provider auto-detected from whichever key is set) ---
# RECOMMENDED free option: Hugging Face FLUX.1-schnell — free token, NO credit card:
#   https://huggingface.co/settings/tokens
HF_TOKEN=
# HF_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell
# Alternatives:
# TOGETHER_API_KEY=                 # Together FLUX.1-schnell-Free (free signup)
# IMAGE_PROVIDER=xai + XAI_API_KEY  # Grok images (needs xAI credits)
# POLLINATIONS_TOKEN=               # legacy host, now heavily rate-limited

# Optional: AI text-to-video. Local ffmpeg slideshow needs no key; this is only
# for true generative video. Pick ONE provider.
# VIDEO_AI_PROVIDER=fal         # "fal" | "replicate" (auto-detected from keys)
# FAL_KEY=
# FAL_VIDEO_MODEL=fal-ai/ltx-video
# REPLICATE_API_TOKEN=
# REPLICATE_VIDEO_MODEL=owner/name

# App settings
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET=change-this-to-random-string
DATA_DIR=./data